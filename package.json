{
  "name": "lorekeeper",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "./node_modules/.bin/vite",
    "dev:lean": "scripts/run-lean-dev.sh",
    "typecheck": "./node_modules/.bin/tsc --noEmit",
    "build": "./node_modules/.bin/tsc && ./node_modules/.bin/vite build",
    "build:frontend": "./node_modules/.bin/vite build",
    "preview": "./node_modules/.bin/vite preview",
    "tauri": "./node_modules/.bin/tauri",
    "test": "./node_modules/.bin/vitest run",
    "test:frontend": "./node_modules/.bin/vitest run",
    "test:watch": "./node_modules/.bin/vitest",
    "test:e2e": "./node_modules/.bin/playwright test --config e2e/playwright.config.ts",
    "lint:rust": "cargo clippy --manifest-path src-tauri/Cargo.toml -- -D warnings",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "verify:frontend": "npm run typecheck && npm run test:frontend && npm run build:frontend",
    "verify:full": "npm run verify:frontend && npm run lint:rust && npm run test:rust",
    "clean:heavy": "scripts/clean-heavy-artifacts.sh",
    "clean:local": "scripts/clean-local-all.sh"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "jsdom": "^28.0.0",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "@playwright/test": "^1.52.0",
    "vitest": "^4.0.18"
  }
}
